# Copy to `.env` (which is gitignored) and fill in the providers you use.
# `.env` is loaded only when you run the server, never on import (so the test
# suite never picks it up). You don't need all three providers.

# ── Claude (Anthropic) ───────────────────────────────────────────────────────
# Long-lived OAuth / subscription token (sk-ant-oat01-...). Mint one with:
#   claude setup-token
# When set, this WINS over the macOS Keychain / Claude Code login — making
# resolution deterministic and Docker-safe (containers have no Keychain), and
# the proxy never reads or rotates the Claude Code app's own login.
CLAUDE_CODE_OAUTH_TOKEN=
# ANTHROPIC_TOKEN=               # alternative name; takes priority if both set

# ── Codex (ChatGPT) and Grok (xAI) ───────────────────────────────────────────
# Normally you log in once with `oauth-proxy login codex` / `oauth-proxy login
# grok` (opens a browser). To bootstrap a fresh host / container with NO browser,
# seed the long-lived refresh token instead — the proxy exchanges it on first
# use and caches the minted bundle under OAUTH_PROXY_HOME.
# Generate these from an already-logged-in machine with:  oauth-proxy export-env
# CODEX_REFRESH_TOKEN=
# CODEX_ACCESS_TOKEN=            # optional
# CODEX_ACCOUNT_ID=             # optional
# GROK_REFRESH_TOKEN=
# GROK_ACCESS_TOKEN=            # optional
# GROK_TOKEN_ENDPOINT=          # optional; defaults to xAI's discovered endpoint

# ── Paths ────────────────────────────────────────────────────────────────────
# Where minted credential bundles are cached. Default: ~/.oauth-proxy
# (legacy name: PROXY_HOME). Use an absolute path — `~` is NOT expanded here.
# OAUTH_PROXY_HOME=/var/lib/oauth-proxy

# ── Optional server settings (defaults shown) ────────────────────────────────
# PROXY_HOST=127.0.0.1
# PROXY_PORT=8787
# PROXY_API_KEY=                 # if set, clients must send Authorization: Bearer <key>
# PROXY_DEFAULT_PROVIDER=anthropic  # backend for an unrecognized model name
# DEFAULT_MODEL=claude-opus-4-8  # substituted for non-Claude model names (e.g. gpt-4o)
# CODEX_DEFAULT_MODEL=gpt-5.2    # substituted for a non-OpenAI name routed to Codex
# GROK_DEFAULT_MODEL=grok-4.3    # substituted for a non-Grok name routed to Grok
# DEFAULT_REASONING_EFFORT=off   # off|low|medium|high|xhigh|max
# PROXY_INCLUDE_REASONING=false  # surface model thinking as reasoning_content
# PROXY_PROMPT_CACHE=true        # inject one ephemeral prompt-cache breakpoint (Claude)
# PROXY_REQUEST_TIMEOUT=900      # upstream read timeout (seconds)
# LOG_LEVEL=INFO                 # DEBUG|INFO|WARNING|...
