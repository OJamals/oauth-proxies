# Copy to `.env` (which is gitignored) and fill in your token.
# Mint one with:  claude setup-token

# Required: your Claude Code OAuth / subscription token (sk-ant-oat01-...).
CLAUDE_CODE_OAUTH_TOKEN=

# Optional server settings (defaults shown).
# PROXY_HOST=127.0.0.1
# PROXY_PORT=8787
# PROXY_API_KEY=                 # if set, clients must send Authorization: Bearer <key>
# DEFAULT_MODEL=claude-opus-4-7  # substituted for non-Claude model names (e.g. gpt-4o)
# DEFAULT_REASONING_EFFORT=off   # off|low|medium|high|xhigh|max
# PROXY_INCLUDE_REASONING=false  # surface Claude thinking as reasoning_content
# PROXY_REQUEST_TIMEOUT=900      # upstream read timeout (seconds)
